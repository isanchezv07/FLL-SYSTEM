---
const title = "LEGO Timer System";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gradient-to-br from-red-100 to-yellow-100 flex flex-col items-center justify-center">
    <div class="text-center p-8">
      <img src="/favicon.svg" alt="LEGO Timer Logo" class="w-24 h-24 mx-auto mb-8" />

      <h1 class="text-6xl font-black text-red-800 mb-4" style={{ fontFamily: 'Arial Black, sans-serif' }}>
        LEGO TIMER
      </h1>
      <p class="text-xl text-gray-700 mb-8">
        Sistema de Temporizador LEGO FTC
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl w-full">
        <a href="/roles/referee/ref" class="block p-8 bg-white rounded-2xl shadow-lg border-4 border-blue-600 hover:shadow-xl transition-all duration-300">
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 bg-blue-600 rounded-lg mb-4 flex items-center justify-center">
              <div class="grid grid-cols-2 gap-1">
                <div class="w-3 h-3 bg-blue-800 rounded-full"></div>
                <div class="w-3 h-3 bg-blue-800 rounded-full"></div>
                <div class="w-3 h-3 bg-blue-800 rounded-full"></div>
                <div class="w-3 h-3 bg-blue-800 rounded-full"></div>
              </div>
            </div>
            <h2 class="text-2xl font-bold text-blue-800 mb-2">Head Referee</h2>
            <p class="text-gray-600">Control principal del temporizador</p>
          </div>
        </a>

        <a href="/displays/timer" class="block p-8 bg-white rounded-2xl shadow-lg border-4 border-green-600 hover:shadow-xl transition-all duration-300">
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 bg-green-600 rounded-lg mb-4 flex items-center justify-center">
              <div class="grid grid-cols-2 gap-1">
                <div class="w-3 h-3 bg-green-800 rounded-full"></div>
                <div class="w-3 h-3 bg-green-800 rounded-full"></div>
                <div class="w-3 h-3 bg-green-800 rounded-full"></div>
                <div class="w-3 h-3 bg-green-800 rounded-full"></div>
              </div>
            </div>
            <h2 class="text-2xl font-bold text-green-800 mb-2">Timer Display</h2>
            <p class="text-gray-600">Pantalla de visualización del temporizador</p>
          </div>
        </a>

        <a href="/roles/admin/admin_dashboard" class="block p-8 bg-white rounded-2xl shadow-lg border-4 border-purple-600 hover:shadow-xl transition-all duration-300">
          <div class="flex flex-col items-center">
            <div class="w-16 h-16 bg-purple-600 rounded-lg mb-4 flex items-center justify-center">
              <div class="grid grid-cols-2 gap-1">
                <div class="w-3 h-3 bg-purple-800 rounded-full"></div>
                <div class="w-3 h-3 bg-purple-800 rounded-full"></div>
                <div class="w-3 h-3 bg-purple-800 rounded-full"></div>
                <div class="w-3 h-3 bg-purple-800 rounded-full"></div>
              </div>
            </div>
            <h2 class="text-2xl font-bold text-purple-800 mb-2">Admin Dashboard</h2>
            <p class="text-gray-600">Gestión de usuarios, matches y brackets</p>
          </div>
        </a>
      </div>

      <footer class="mt-12 text-sm text-gray-500 text-center">
        Sistema LEGO Timer FTC
      </footer>
    </div>
  </body>
</html>