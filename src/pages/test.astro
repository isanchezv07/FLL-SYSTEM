---
import { ViewTransitions } from 'astro:transitions';
import InteractiveMap from '@/components/roles/referee/Referee';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Torneo FLL</title>
    
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href="/icono.png" /> 
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="theme-color" content="#00853E" />
    
    <ViewTransitions />
  </head>
  <body style="font-family: sans-serif; text-align: center; margin: 0; background-color: #f4f4f4;">    
    
    <div id="app-container" style="padding: 20px;">
      <InteractiveMap client:load />
    </div>

    <button id="btn-fullscreen" class="floating-btn">
      <svg id="icon-expand" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path>
      </svg>
      <span id="text-fullscreen">Pantalla Completa</span>
    </button>

    <style>
      .floating-btn {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 10000; /* Lo ponemos muy alto para que siempre se vea */
        background-color: #00853E;
        color: white;
        border: none;
        border-radius: 50px;
        padding: 12px 20px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        display: flex;
        align-items: center;
        gap: 8px;
      }
      
      /* EL TRUCO PARA SAFARI: Esta clase se activará con el botón */
      .ios-fullscreen {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 100vw !important;
        height: 100vh !important;
        z-index: 9999 !important;
        background-color: #f4f4f4 !important;
        overflow-y: auto !important;
        padding: 0 !important;
        margin: 0 !important;
        display: flex;
        justify-content: center;
        align-items: center;
      }
    </style>

    <script>
      document.addEventListener('astro:page-load', () => {
        const btn = document.getElementById('btn-fullscreen');
        const textSpan = document.getElementById('text-fullscreen');
        const iconPath = document.querySelector('#icon-expand path');
        const appContainer = document.getElementById('app-container');

        let isFakeFullscreen = false;

        if (!btn || !appContainer) return;

        btn.addEventListener('click', () => {
          // Detectamos si el navegador soporta pantalla completa real (Android/PC) o si es Safari (iPhone)
          const canRealFullscreen = document.fullscreenEnabled || document.webkitFullscreenEnabled;

          if (!document.fullscreenElement && !document.webkitFullscreenElement && !isFakeFullscreen) {
            
            // INTENTAR ENTRAR A PANTALLA COMPLETA
            if (canRealFullscreen) {
              const req = appContainer.requestFullscreen || appContainer.webkitRequestFullscreen;
              if(req) {
                req.call(appContainer).catch(() => toggleFakeFullscreen());
              }
            } else {
              // Si es Safari de iPhone, forzamos el truco CSS
              toggleFakeFullscreen();
            }
            
            textSpan.textContent = "Salir";
            iconPath.setAttribute('d', 'M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3');
          
          } else {
            
            // SALIR DE PANTALLA COMPLETA
            if (document.fullscreenElement || document.webkitFullscreenElement) {
              const exit = document.exitFullscreen || document.webkitExitFullscreen;
              if(exit) exit.call(document);
            }
            if (isFakeFullscreen) {
              toggleFakeFullscreen();
            }

            textSpan.textContent = "Pantalla Completa";
            iconPath.setAttribute('d', 'M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3');
          }
        });

        // Función que pone la clase CSS mágica
        function toggleFakeFullscreen() {
          appContainer.classList.toggle('ios-fullscreen');
          isFakeFullscreen = !isFakeFullscreen;
          
          // Pequeño truco extra: intenta ocultar un poco la barra de direcciones en Safari
          if (isFakeFullscreen) {
            window.scrollTo(0, 1);
          }
        }
      });
    </script>
  </body>
</html>